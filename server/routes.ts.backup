          conceptualLineage: {
            passageA: {
              primaryInfluences: "Analysis currently unavailable - please try again later.",
              intellectualTrajectory: "Analysis currently unavailable - please try again later.",
            },
            passageB: {
              primaryInfluences: "Analysis currently unavailable - please try again later.", 
              intellectualTrajectory: "Analysis currently unavailable - please try again later.",
            },
          },
          semanticDistance: {
            passageA: {
